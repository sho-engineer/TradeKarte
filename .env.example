# Anthropic Claude API(必須)— サーバーサイドのみで使用。クライアントに露出しない
ANTHROPIC_API_KEY=

# Supabase(認証・保存を使う場合に設定。未設定でも保存なしのお試しモードで動作)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 無料プランの月間レビュー回数上限(省略時 10)
FREE_MONTHLY_LIMIT=10

# Stripe Checkout の決済リンク(実課金を有効化するときに設定)
NEXT_PUBLIC_STRIPE_CHECKOUT_URL=

# 開発/デモ用:1 にすると Claude API を呼ばず固定レビューを返す(APIキー不要)
MOCK_REVIEW=

# Supabase(必須)— Anonymous Sign-In を有効化したプロジェクト
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用。クライアントへ露出させない
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic(必須)— サーバー専用。クライアントへ露出させない
ANTHROPIC_API_KEY=
# モデルIDはコードへ直書きせず env で切り替える(比較候補: claude-sonnet-4-6 / claude-opus-4-8)
ANTHROPIC_MODEL=claude-sonnet-5

# アクセスコード(必須)— サーバー専用
APP_ACCESS_CODE=
# Cookie署名鍵(必須)— サーバー専用。十分に長く(例: openssl rand -base64 48)
APP_ACCESS_COOKIE_SECRET=
